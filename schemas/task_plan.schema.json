{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maa-remote/schemas/task_plan.schema.json",
  "title": "TaskPlan",
  "description": "意图识别（DeepSeek）输出的结构化任务计划。Router 用本 schema 强校验；非法则带错误信息重试一次。",
  "type": "object",
  "additionalProperties": false,
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["run", "copilot", "ask_stage_selection", "clarify", "reject", "advise", "approve", "patch"],
      "description": "run=执行计划；copilot=抄作业打活动关，触发 prts.plus 作业匹配流程（不直接执行）；ask_stage_selection=想刷活动但没定具体关，触发关卡菜单；clarify=意图不清需追问；reject=非任务/超范围；advise=只读建议；approve=确认态同意执行；patch=确认态修改 pending plan"
    },
    "copilot": {
      "type": "object",
      "additionalProperties": false,
      "description": "action=copilot 时使用；只是触发抄作业匹配流程，不含执行细节。stage 是关卡显示号，由 Router 侧 catalog 解析为 level_id 并查作业。",
      "properties": {
        "stage": {
          "type": "string",
          "description": "关卡显示号（如 HS-9）。空串=不指定单关，配合 scope=all_new 打当期全部新关；scope=single 但用户没给确切关卡时也可留空，由 Router 走选关"
        },
        "scope": {
          "type": "string",
          "enum": ["single", "all_new"],
          "description": "single=抄作业打指定单关；all_new=抄作业打当期全部新活动关"
        }
      },
      "required": ["scope"]
    },
    "startup": {
      "type": "boolean",
      "description": "开局：唤醒并进入主界面（含收邮件）。恒为 true——模拟器可能是冷启动、游戏未开；StartUp 幂等，已在游戏内时秒过"
    },
    "recruit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable": { "type": "boolean" },
        "max_times": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "description": "公开招募次数上限，默认 4"
        }
      },
      "required": ["enable"]
    },
    "infrast": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enable": { "type": "boolean" } },
      "required": ["enable"],
      "description": "基建换班 + 领日常奖励"
    },
    "mall": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enable": { "type": "boolean" } },
      "required": ["enable"],
      "description": "信用商店"
    },
    "award": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "enable": { "type": "boolean" } },
      "required": ["enable"],
      "description": "领取日常/周常奖励"
    },
    "fight": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable": { "type": "boolean" },
        "stage": {
          "type": "string",
          "description": "关卡号；空串=当前/上次关卡。活动关卡（如 UR-8）若用户没明确给出，应改用 action=ask_stage_selection 而不是在此瞎填"
        },
        "times": {
          "type": "integer",
          "minimum": 1,
          "description": "作战次数；缺省则由 MAA 按理智自动决定"
        },
        "expiring_medicine": {
          "type": "boolean",
          "description": "只吃即将过期的理智药（揉揉乐）。默认 true"
        },
        "medicine": {
          "type": "integer",
          "minimum": 0,
          "maximum": 999,
          "description": "动用囤积理智药的数量。默认 0（不动囤药）。仅用户明确要求时才 >0；>0 时 Router 会先向用户二次确认再执行"
        },
        "stone": {
          "type": "integer",
          "minimum": 0,
          "maximum": 999,
          "description": "碎石数量。默认 0（绝不碎石）。仅用户明确要求碎石时才 >0；>0 时 Router 会先向用户二次确认再执行"
        },
        "series": {
          "type": "integer",
          "minimum": -1,
          "maximum": 6,
          "description": "代理连战倍率。0=由 MAA 按当前理智自动选择最大可用倍率；1~6=指定倍率；-1=禁用切换。默认 0"
        }
      },
      "required": ["enable"]
    },
    "clarify_question": {
      "type": "string",
      "description": "action=clarify 时，回给用户的追问"
    },
    "note": {
      "type": "string",
      "description": "对用户原始意图的简短复述，供 Reporter 润色汇报时参考"
    },
    "advise_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "action=advise 时使用；只能引用 snapshot 中存在的关卡 code 或 alias stage，最终回复由 Router 渲染"
    },
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "description": "action=patch 时使用；只包含用户明确要修改的 TaskPlan 字段子集",
      "properties": {
        "startup": { "type": "boolean" },
        "recruit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enable": { "type": "boolean" },
            "max_times": {
              "type": "integer",
              "minimum": 0,
              "maximum": 4
            }
          }
        },
        "infrast": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enable": { "type": "boolean" } }
        },
        "mall": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enable": { "type": "boolean" } }
        },
        "award": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enable": { "type": "boolean" } }
        },
        "fight": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enable": { "type": "boolean" },
            "stage": { "type": "string" },
            "times": { "type": "integer", "minimum": 1 },
            "expiring_medicine": { "type": "boolean" },
            "medicine": { "type": "integer", "minimum": 0, "maximum": 999 },
            "stone": { "type": "integer", "minimum": 0, "maximum": 999 },
            "series": { "type": "integer", "minimum": -1, "maximum": 6 }
          }
        },
        "note": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action": { "const": "clarify" } } },
      "then": { "required": ["action", "clarify_question"] }
    },
    {
      "if": { "properties": { "action": { "const": "patch" } } },
      "then": { "required": ["action", "patch"] }
    },
    {
      "if": { "properties": { "action": { "const": "advise" } } },
      "then": { "required": ["action", "advise_refs"] }
    },
    {
      "if": { "properties": { "action": { "const": "copilot" } } },
      "then": { "required": ["action", "copilot"] }
    },
    {
      "if": { "required": ["copilot"] },
      "then": { "properties": { "action": { "const": "copilot" } } }
    }
  ]
}
